# BACnet Virtual Device — Configuratie (.env formaat)
#
# Kopieer dit bestand naar .env of exporteer de variabelen
# voordat je het script start.
#
# Gebruik: source config.env && python virtual_bacnet_device.py

# BACnet Device ID (uniek op het netwerk, 0-4194302)
export BACNET_DEVICE_ID=599

# BACnet apparaatnaam (zichtbaar bij Who-Is / I-Am)
export BACNET_DEVICE_NAME="VirtueleThermostaat"

# IP-adres en subnetmasker in CIDR notatie
# Wijzig dit naar het IP-adres van jouw machine op het BACnet netwerk
# Voorbeelden:
#   "192.168.1.100/24"   — specifiek adres
#   "0.0.0.0/24"         — luister op alle interfaces
export BACNET_ADDRESS="0.0.0.0/24"

# BACnet/IP UDP poort (standaard: 47808 = 0xBAC0)
export BACNET_PORT=47808

# Hoe vaak de gesimuleerde waarden veranderen (in seconden)
export UPDATE_INTERVAL=5
